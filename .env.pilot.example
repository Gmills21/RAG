# Environment variables for single-customer VPS pilot deployment
# Copy this file to .env and configure for your customer

# Public hostname for the pilot deployment
# This should be a dedicated domain or subdomain for this customer
# Example: customer-name-kb.yourdomain.com
PUBLIC_HOST=example.com

# Basic authentication credentials (optional but recommended)
# Generate password hash with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=

# Notes:
# - This configuration is for DEDICATED SINGLE-CUSTOMER VPS ONLY
# - Do NOT use for local testing (no .env needed for local docker-compose.yml)
# - Use one VPS and one .env per customer for first pilots
# - Keep customer-specific data in separate folders
# - Generate a strong password and hash for basic auth
# - Configure DNS to point PUBLIC_HOST to your VPS IP before deployment
# - Caddy will automatically obtain Let's Encrypt HTTPS certificates

# Example basic auth hash generation:
# $ docker run --rm caddy:2-alpine caddy hash-password --plaintext 'MySecurePassword123'
# $2a$14$Zkx19XLiW6VYouLHR5NmfOFU0z2GTNmpBnk2dPxN7lAaR9V9qWHmG

# Deployment checklist:
# 1. Set PUBLIC_HOST to customer's domain
# 2. Configure DNS A record
# 3. Generate and set BASIC_AUTH_HASH
# 4. Copy this file to .env:                 cp .env.pilot.example .env
# 5. Copy the Caddy config into place:       cp Caddyfile.example Caddyfile
#    (docker-compose.pilot.yml mounts ./Caddyfile, not ./Caddyfile.example)
# 6. Run: docker compose -f docker-compose.yml -f docker-compose.pilot.yml up -d
# 7. Verify HTTPS works at https://${PUBLIC_HOST}
# 8. Test basic auth login
# 9. Upload only approved customer docs
# 10. Configure Kotaemon models for Ollama on VPS
