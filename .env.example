# Environment variables for LOCAL development
#
# This file is optional for local use. The local docker-compose.yml works
# without a .env file because it provides sane defaults for everything below.
# Copy this file to `.env` only if you want to override a default.
#
# For pilot/VPS deployments, use `.env.pilot.example` instead.

# Host port + bind address for the Kotaemon UI.
# Default keeps the app bound to localhost so it is NOT exposed on your LAN.
# Examples:
#   KOTAEMON_PORT=127.0.0.1:7860   # default — localhost only
#   KOTAEMON_PORT=127.0.0.1:7861   # use a different port if 7860 is taken
KOTAEMON_PORT=127.0.0.1:7860
