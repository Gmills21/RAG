# Environment variables for local development
# Copy to .env and fill in values. Never commit .env with real secrets.

# dev-ollama (optional — Ollama does not validate the key)
OLLAMA_API_KEY=ollama

# demo-hosted / pilot-hosted (optional for local dev; required for demos and pilots)
# OPENAI_API_KEY=sk-...

# Azure OpenAI alternative (optional)
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
