# Environment variables for local development
# Copy to .env and fill in values. Never commit .env with real secrets.

# dev-ollama: personal/local testing only.
# Ollama does not validate the key, but Kotaemon expects a non-empty value.
OLLAMA_API_KEY=ollama

# demo-hosted / pilot-hosted:
# required for production-speed prospect demos and paid pilots.
# OPENAI_API_KEY=sk-...

# Azure OpenAI alternative:
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
